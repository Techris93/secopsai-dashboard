SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace_me
APP_NAME=SecOpsAI Mission Control
DASHBOARD_AUTH_REQUIRED=true
DISCORD_SERVER_ID=1484917962245668874

# Optional notification webhooks used by /api/discord-notify
# Requests must include x-discord-notify-token or Bearer with this value.
DISCORD_NOTIFY_TOKEN=
DISCORD_OPS_LOG_WEBHOOK=
DISCORD_KANBAN_UPDATES_WEBHOOK=

# Preferred hosted run-output mode: bind an R2 bucket named RUN_OUTPUTS
# and optionally prefix keys with RUN_OUTPUT_R2_PREFIX.
RUN_OUTPUT_R2_BINDING=RUN_OUTPUTS
RUN_OUTPUT_R2_PREFIX=

# Fallback hosted run-output mode: proxy to an upstream helper that accepts ?path=
# and returns either { ok, text } JSON or plain text.
RUN_OUTPUT_BASE_URL=
RUN_OUTPUT_AUTH_HEADER=
RUN_OUTPUT_AUTH_TOKEN=

# Blog Ops control plane. Keep both token values secret.
BLOG_OPS_OWNER=Techris93
BLOG_OPS_REPO=secopsai
BLOG_OPS_WORKFLOW=blog-ops.yml
BLOG_OPS_REF=main
BLOG_OPS_GITHUB_TOKEN=
BLOG_OPS_ADMIN_TOKEN=

# Triage Ops uses the local/private SecOpsAI helper for supply-chain alerts
# and Campaign Research actions.
# Hosted Pages can proxy /api/secopsai/* to this helper.
SECOPSAI_HELPER_BASE_URL=
SECOPSAI_HELPER_AUTH_HEADER=
SECOPSAI_HELPER_AUTH_TOKEN=
# Preferred hosted canonical workspace. These credentials are consumed only by
# the Pages Worker and are never emitted through config.js.
SECOPSAI_CORE_API_URL=
SECOPSAI_CORE_READ_TOKEN=
SECOPSAI_CORE_INTELLIGENCE_TOKEN=
SECOPSAI_MCP_URL=https://secopsai-chatgpt-app.onrender.com/mcp
SECOPSAI_EDGE_API_URL=
SECOPSAI_EDGE_OPERATIONS_TOKEN=
# Deprecated local-helper migration fallback only. Hosted mode does not use it.
SECOPSAI_EDGE_ADMIN_TOKEN=
# Required for protected Triage Ops write actions such as close, escalate,
# persist campaign findings, and create campaign blog drafts.
TRIAGE_OPS_ADMIN_TOKEN=
