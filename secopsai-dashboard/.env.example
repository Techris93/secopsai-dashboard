# SecOpsAI dashboard local environment
# Copy to .env and fill in real values.

SUPABASE_URL=https://wjxvdjsatfepfcbxunfs.supabase.co
SUPABASE_ANON_KEY=replace_me
APP_NAME=SecOpsAI Mission Control
DISCORD_SERVER_ID=1484917962245668874

# Discord webhooks used by the dashboard UI for notifications
DISCORD_OPS_LOG_WEBHOOK=
DISCORD_KANBAN_UPDATES_WEBHOOK=

# Bot token used by the inbound Discord dispatcher
DISCORD_BOT_TOKEN=

# Dispatcher execution mode.
# - openclaw: renders the role prompt directly from secopsai-org/acp-fallback/prompts/*.md
#              and runs it with `openclaw agent` (no ACP backend dependency)
# - codex / claude: keeps the existing shell-template executor behavior
# Supported placeholders for codex/claude templates:
#   {prompt_file} -> quoted path to rendered prompt markdown file
#   {prompt}      -> quoted prompt text
# Example Codex command:
# DISCORD_DISPATCHER_CODEX_COMMAND=codex exec --skip-git-repo-check -m gpt-5 --full-auto {prompt_file}
# Example Claude command:
# DISCORD_DISPATCHER_CLAUDE_COMMAND=claude --print --permission-mode bypassPermissions {prompt_file}
DISCORD_DISPATCHER_EXECUTOR=openclaw
DISCORD_DISPATCHER_CODEX_COMMAND=
DISCORD_DISPATCHER_CLAUDE_COMMAND=

# Poll interval in seconds
DISCORD_DISPATCHER_POLL_SECONDS=5

# Reliability guardrails for long-running OpenClaw tasks.
# Keep the OpenClaw timeout comfortably above the real task duration.
DISCORD_DISPATCHER_OPENCLAW_TIMEOUT_SECONDS=900
# Outer process timeout should exceed the OpenClaw timeout to allow clean flush/JSON output.
DISCORD_DISPATCHER_OPENCLAW_PROCESS_TIMEOUT_SECONDS=1020
# Prompt budgeting to avoid oversized rendered prompts and argument/payload issues.
DISCORD_DISPATCHER_TASK_MAX_CHARS=12000
DISCORD_DISPATCHER_CONTEXT_MAX_CHARS=2500
DISCORD_DISPATCHER_MEMORY_MAX_CHARS=2500
DISCORD_DISPATCHER_PROMPT_MAX_CHARS=18000

# Leave blank to watch all active channel_routes, or provide a comma-separated allowlist.
DISCORD_DISPATCHER_CHANNELS=

# Optional: allow bot-authored [SELFTEST] messages to be processed for live smoke tests.
DISCORD_DISPATCHER_ENABLE_SELFTEST=false
