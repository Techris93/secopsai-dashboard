# SecOpsAI dashboard local environment
# Copy to .env and fill in real values.

SUPABASE_URL=https://wjxvdjsatfepfcbxunfs.supabase.co
SUPABASE_ANON_KEY=replace_me
APP_NAME=SecOpsAI Mission Control
DISCORD_SERVER_ID=1484917962245668874

# Discord webhooks used by the dashboard UI for notifications
DISCORD_OPS_LOG_WEBHOOK=
DISCORD_KANBAN_UPDATES_WEBHOOK=

# Bot token used by the inbound Discord dispatcher
DISCORD_BOT_TOKEN=

# Dispatcher is codex-only. Provide a shell command template to execute the rendered prompt.
# Supported placeholders:
#   {prompt_file} -> quoted path to rendered prompt markdown file
#   {prompt}      -> quoted prompt text
# Example (replace with your real Codex invocation):
# DISCORD_DISPATCHER_CODEX_COMMAND=codex <your-flags> {prompt_file}
DISCORD_DISPATCHER_EXECUTOR=codex
DISCORD_DISPATCHER_CODEX_COMMAND=

# Optional tuning for inbound dispatcher polling loop
DISCORD_DISPATCHER_POLL_SECONDS=5

# Optional comma-separated allowlist of watched channel IDs
DISCORD_DISPATCHER_CHANNELS=1484922078837870794
